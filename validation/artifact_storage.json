{
  "schema_version": "factory-vision-artifact-storage-v1",
  "updated_at": "2026-05-02",
  "policy": {
    "github_role": "source_of_truth_for_code_docs_manifests_registry_small_proof_summaries",
    "working_cache_role": "repo data/ and models/ paths remain the paths used by scripts and app validation",
    "heavy_artifact_role": "raw videos, full frame dumps, training datasets, embedding databases, and large model libraries live outside normal Git",
    "cloud_upload_rule": "Do not silently upload factory footage or heavy artifacts to cloud storage; require explicit permission."
  },
  "local_artifact_root": {
    "path": "/Users/thomas/FactoryVisionArtifacts",
    "status": "active_primary_local_artifact_root",
    "directories": {
      "raw_videos": "videos/raw",
      "reports": "reports",
      "models": "models",
      "frames": "frames",
      "embeddings": "embeddings",
      "backups": "backups"
    }
  },
  "future_remote_artifact_store": {
    "preferred_provider": "cloudflare_r2",
    "fallback_provider": "backblaze_b2",
    "bucket_placeholder": "factory-vision-artifacts",
    "status": "not_configured",
    "uri_pattern": "r2://factory-vision-artifacts/{artifact_relpath}"
  },
  "storage_classes": [
    {
      "artifact_type": "raw_video",
      "git_policy": "never_normal_git",
      "local_artifact_dir": "videos/raw",
      "repo_working_cache": "data/videos/from-pc"
    },
    {
      "artifact_type": "proof_report",
      "git_policy": "commit_small_registry_relevant_reports_when_needed",
      "local_artifact_dir": "reports",
      "repo_working_cache": "data/reports"
    },
    {
      "artifact_type": "model_checkpoint",
      "git_policy": "commit_small_diagnostic_models_only_when_needed; move large reusable library models to artifact storage",
      "local_artifact_dir": "models",
      "repo_working_cache": "models"
    },
    {
      "artifact_type": "review_frame_or_training_frame",
      "git_policy": "commit_selected_proof_frames_only; keep full dumps outside normal Git",
      "local_artifact_dir": "frames",
      "repo_working_cache": "data/videos/review_frames"
    },
    {
      "artifact_type": "embedding_database",
      "git_policy": "never_normal_git",
      "local_artifact_dir": "embeddings",
      "repo_working_cache": "data/library"
    }
  ],
