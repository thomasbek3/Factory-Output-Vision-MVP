{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "factory-vision-event-evidence.schema.json",
  "title": "Factory Vision Event Evidence Packet",
  "type": "object",
  "required": [
    "schema_version",
    "case_id",
    "video",
    "privacy_mode",
    "source_artifacts",
    "model_settings",
    "windows",
    "review_window_metadata"
  ],
  "properties": {
    "schema_version": { "const": "factory-vision-event-evidence-v1" },
    "case_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "number" },
    "privacy_mode": {
      "type": "string",
      "enum": ["offline_local", "cloud_assisted_setup", "cloud_assisted_audit"]
    },
    "video": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string" },
        "sha256": { "type": "string" },
        "duration_sec": { "type": ["number", "null"] },
        "width": { "type": ["integer", "null"] },
        "height": { "type": ["integer", "null"] },
        "codec": { "type": ["string", "null"] }
      }
    },
    "source_artifacts": {
      "type": "object",
      "required": ["observed_events_path"],
      "properties": {
        "manifest_path": { "type": ["string", "null"] },
        "observed_events_path": { "type": ["string", "null"] },
        "truth_ledger_path": { "type": ["string", "null"] },
        "comparison_report_path": { "type": ["string", "null"] }
      }
    },
    "model_settings": {
      "type": "object",
      "properties": {
        "counting_mode": { "type": ["string", "null"] },
        "demo_count_mode": { "type": ["string", "null"] },
        "model_path": { "type": ["string", "null"] },
        "runtime_calibration_path": { "type": ["string", "null"] },
        "processing_fps": { "type": ["number", "null"] },
        "reader_fps": { "type": ["number", "null"] },
        "yolo_confidence": { "type": ["number", "null"] },
        "event_track_max_age": { "type": ["integer", "null"] },
        "event_track_min_frames": { "type": ["integer", "null"] },
        "event_detection_cluster_distance": { "type": ["number", "null"] }
      }
    },
    "windows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "window_id",
          "window_type",
          "time_window",
          "frame_window",
          "confidence_tier",
          "duplicate_risk",
          "miss_risk",
          "label_authority_tier"
        ],
        "properties": {
          "window_id": { "type": "string", "minLength": 1 },
          "window_type": {
            "type": "string",
            "enum": ["count_event", "negative_background", "uncertain_event", "miss_candidate", "duplicate_candidate"]
          },
          "event_index": { "type": ["integer", "null"] },
          "time_window": {
            "type": "object",
            "required": ["start_sec", "end_sec", "center_sec"],
            "properties": {
              "start_sec": { "type": "number" },
              "end_sec": { "type": "number" },
              "center_sec": { "type": "number" }
            }
          },
          "frame_window": {
            "type": "object",
            "required": ["start_frame_index", "end_frame_index", "center_frame_index"],
            "properties": {
              "start_frame_index": { "type": ["integer", "null"] },
              "end_frame_index": { "type": ["integer", "null"] },
              "center_frame_index": { "type": ["integer", "null"] },
              "frame_index_basis": { "type": "string" }
            }
          },
          "count_event_evidence": { "type": ["object", "null"] },
          "review_window": { "type": "object" },
          "confidence_tier": { "type": "string", "enum": ["high", "medium", "low", "unknown"] },
          "duplicate_risk": { "type": "string", "enum": ["high", "medium", "low", "unknown"] },
          "miss_risk": { "type": "string", "enum": ["high", "medium", "low", "unknown"] },
          "label_authority_tier": { "type": "string", "enum": ["gold", "silver", "bronze"] },
          "notes": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "review_window_metadata": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["window_id", "start_sec", "end_sec", "review_status"],
        "properties": {
          "window_id": { "type": "string" },
          "start_sec": { "type": "number" },
          "end_sec": { "type": "number" },
          "review_status": { "type": "string" }
        }
      }
    }
  }
}
