{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "factory-vision-active-learning-dataset.schema.json",
  "title": "Factory Vision Active Learning Dataset",
  "type": "object",
  "required": [
    "schema_version",
    "dataset_id",
    "case_ids",
    "privacy_mode",
    "label_tier_policy",
    "items"
  ],
  "properties": {
    "schema_version": { "const": "factory-vision-active-learning-dataset-v1" },
    "dataset_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "number" },
    "case_ids": { "type": "array", "items": { "type": "string" } },
    "privacy_mode": {
      "type": "string",
      "enum": ["offline_local", "cloud_assisted_setup", "cloud_assisted_audit"]
    },
    "label_tier_policy": {
      "type": "object",
      "required": ["validation_truth_requires_gold", "bronze_training_allowed", "silver_validation_allowed"],
      "properties": {
        "validation_truth_requires_gold": { "const": true },
        "bronze_training_allowed": { "type": "boolean" },
        "silver_validation_allowed": { "const": false }
      }
    },
    "source_label_paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "splits": {
      "type": "object",
      "properties": {
        "train": { "type": "array" },
        "val": { "type": "array" },
        "test": { "type": "array" },
        "review": { "type": "array" }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "item_id",
          "case_id",
          "window_id",
          "split",
          "label_authority_tier",
          "review_status",
          "validation_truth_eligible"
        ],
        "properties": {
          "item_id": { "type": "string" },
          "case_id": { "type": "string" },
          "window_id": { "type": "string" },
          "event_id": { "type": ["string", "null"] },
          "split": { "type": "string", "enum": ["train", "val", "test", "review"] },
          "evidence_path": { "type": ["string", "null"] },
          "label_path": { "type": ["string", "null"] },
          "label_authority_tier": { "type": "string", "enum": ["gold", "silver", "bronze"] },
          "review_status": { "type": "string", "enum": ["pending", "approved", "rejected", "edited", "unclear"] },
          "teacher_output_status": {
            "type": ["string", "null"],
            "enum": ["countable", "completed", "in_transit", "static_stack", "worker_only", "unclear", null]
          },
          "duplicate_risk": { "type": "string", "enum": ["high", "medium", "low", "unknown"] },
          "miss_risk": { "type": "string", "enum": ["high", "medium", "low", "unknown"] },
          "validation_truth_eligible": { "type": "boolean" },
          "training_eligible": { "type": "boolean" }
        }
      }
    }
  }
}
